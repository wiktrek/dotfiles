{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 10,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "pulseaudio", "network", "cpu", "memory", "battery"],

  "hyprland/workspaces": {
    "all-outputs": true,
    "format": "{icon} {name}",
    "format-icons": {
      "active": "",
      "default": "",
      "empty": "",
      "special": "󰎉",
      "visible": "󰖯"
    }
  },

  "hyprland/window": {
    "format": "{title}",
    "separate-outputs": true,
    "max-length": 50
  },

  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "format": {
        "months": "<span color='#a6e3a1'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'><b>{}</b></span>",
        "weeks": "<span color='#6c7086'><b>W{}</b></span>",
        "weekdays": "<span color='#89b4fa'><b>{}</b></span>",
        "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    }
  },

  "tray": {
    "spacing": 10
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 muted",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "scroll-step": 5
  },

  "network": {
    "format-wifi": "󰖩 {signalStrength}%",
    "format-ethernet": "󰈁 wired",
    "format-disconnected": "󰖪 offline",
    "tooltip-format": "{ifname}\n{ipaddr}/{cidr}\n{essid}",
    "max-length": 20
  },

  "cpu": {
    "format": "󰍛 {usage}%",
    "tooltip": true
  },

  "memory": {
    "format": "󰘚 {percentage}%"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄 {capacity}%",
    "format-full": "󰁹 {capacity}%",
    "format-icons": ["󰂎", "󰁺", "󰁼", "󰁾", "󰂀", "󰂂", "󰁹"]
  }
}